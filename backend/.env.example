DATABASE_URL=postgresql://user:password@localhost:5432/rideflow
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
PORT=3001
NODE_ENV=development

# Admin API key (generate with: openssl rand -hex 32)
ADMIN_KEY=

# AI service (optional – leave empty for mock mode)
AI_MODEL=gpt-mock

# Hosting region label shown in /api/v1/services/hosting/status
HOSTING_REGION=us-east-1

# Hetzner Storage Box backup (optional)
HETZNER_BACKUP_USER=
HETZNER_BACKUP_HOST=
BACKUP_DIR=/tmp/ride-flow-backups

# Agent tuning (all optional – defaults shown)
MEMORY_THRESHOLD_MB=512
SECURITY_MAX_FAILURES=10
SECURITY_WINDOW_MINUTES=15
SECURITY_BLOCK_MINUTES=60
HIGH_MEM_MB=400
