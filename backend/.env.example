DATABASE_URL=postgresql://user:password@localhost:5432/rideflow
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
PORT=3001
NODE_ENV=development

# Security
REQUIRE_API_KEY=false
API_KEY_SECRET=change-me-to-a-long-random-secret
SECURITY_BLOCK_THRESHOLD=10
SECURITY_WINDOW_MINUTES=15
SECURITY_BLOCK_HOURS=24
SECURITY_INTERVAL_MS=300000

# Analytics
ANALYTICS_INTERVAL_MS=3600000
ANALYTICS_ANOMALY_PCT=30

# Backups
BACKUP_DIR=/tmp/ride-flow-backups
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_MS=21600000

# Monitoring
MEMORY_THRESHOLD_MB=512
