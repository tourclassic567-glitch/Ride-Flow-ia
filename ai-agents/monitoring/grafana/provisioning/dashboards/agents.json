{
  "id": null,
  "uid": "rideflow-agents",
  "title": "Ride-Flow IA – Agent Dashboard",
  "tags": ["ride-flow", "agents"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Agent Ticks / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(agent_ticks_total[1m]) * 60",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Agent Errors / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(agent_errors_total[1m]) * 60",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Surge Multiplier",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizValue": 1,
        "maxVizValue": 3
      },
      "targets": [
        {
          "expr": "surge_multiplier",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Drivers",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        { "expr": "active_drivers", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Rides Requested",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rides_requested_total", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Rides Matched",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "rides_matched_total", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP Latency p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Security Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "rate(security_events_total[1m]) * 60",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Payment Intents",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "rate(payment_intents_total[1m]) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
