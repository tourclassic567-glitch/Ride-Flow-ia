# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=rideflow
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=rideflow
DATABASE_URL=postgresql+asyncpg://rideflow:change_me_strong_password@postgres:5432/rideflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# ── OpenAI (optional – agents work without it via rule-based fallback) ────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Stripe (optional – mock mode if not set) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_64_random_characters
ADMIN_API_KEY=replace_with_admin_key

# ── Agent intervals (seconds) ─────────────────────────────────────────────────
PRICING_AGENT_INTERVAL=60
MATCHING_AGENT_INTERVAL=10
MONITORING_AGENT_INTERVAL=30
REVENUE_AGENT_INTERVAL=300
ANALYTICS_AGENT_INTERVAL=120
SECURITY_AGENT_INTERVAL=60

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password
